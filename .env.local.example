# ============================================================================
# Arbor — environment variables. Copy to `.env.local` and fill in.
# The app runs fully in MOCK MODE with none of these set. Each block "flips on"
# the moment its keys are present.
# ============================================================================

# ---- Supabase (auth, DB, realtime) — enables the whole live backend ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — pipelines + admin user mgmt

# ---- Anthropic (LLM signal extraction) — required for ingestion pipelines ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# ---- Ingestion (cron) ----
CRON_SECRET=                        # Bearer token guarding /api/ingest/* + Vercel cron
SEC_USER_AGENT=Arbor Research you@example.com   # SEC EDGAR requires a descriptive UA
INGEST_RSS_FEEDS=                   # optional comma-separated RSS feed override

# ---- Google Custom Search (private-asset web signals) — optional ----
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# ---- Earnings-call transcripts (Financial Modeling Prep) — optional ----
# Both required to enable. Scans parent-company earnings calls for divestiture
# signals as part of the carveout pipeline.
FMP_API_KEY=
TRANSCRIPT_TICKERS=                 # comma-separated parent tickers, e.g. DOW,DD,GE
# FMP_BASE_URL=                     # optional host override

# ---- Logo enrichment (Clearbit free autocomplete, no key) ----
# On by default for newly-created companies. Set to 1 to disable network lookups.
LOGO_API_DISABLED=

# ---- Typesense (search + entity resolution) — optional, falls back to ilike ----
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PORT=                     # optional (default 443 remote / 8108 localhost)
TYPESENSE_PROTOCOL=                 # optional (default https remote / http localhost)

# ---- Pipeline alerts (Slack-compatible incoming webhook) — optional ----
# Posted to on pipeline errors / crashes and custom alert rule webhooks. No-op if unset.
ALERT_WEBHOOK_URL=   # Slack-compatible incoming webhook
TEAMS_WEBHOOK_URL=   # Microsoft Teams incoming webhook (MessageCard format); fans out alongside Slack

# ---- Error tracking (Sentry) — optional, dormant until DSN set ----
SENTRY_DSN=                          # server + edge
NEXT_PUBLIC_SENTRY_DSN=              # browser
SENTRY_TRACES_SAMPLE_RATE=0.1        # optional
# Source-map upload (readable stack traces in Sentry) — set all three in CI/Vercel
# and wrap next.config with withSentryConfig({ org, project, authToken }). Optional.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Every response carries an `x-request-id`; it appears in structured logs +
# Sentry as `requestId` for end-to-end correlation. Quote it in bug reports.

# ---- Transactional email (Resend) — optional, dormant until both set ----
# Powers team invites (admin → invite). Without it, invites still provision the
# user and the admin is shown the raw accept link to share manually.
RESEND_API_KEY=
EMAIL_FROM=Arbor <noreply@yourdomain.com>
NEXT_PUBLIC_APP_URL=                 # e.g. https://arbor.yourdomain.com (invite redirect base)

# ---- Cron: freshness SLA + data retention (Vercel crons) — optional ----
FRESHNESS_MAX_HOURS=24          # alert if the newest signal is older than this
DIGEST_WINDOW_HOURS=24          # watchlist digest looks back this many hours (needs email)
RETAIN_DEADLETTER_DAYS=30       # purge signal_failures older than N days
RETAIN_USAGE_DAYS=180           # purge llm_usage older than N days
RETAIN_RUNS_DAYS=90             # purge pipeline_runs older than N days
RETAIN_ORPHAN_SIGNAL_DAYS=365   # purge unmatched (no-company) raw signals older than N

# ---- Billing (Stripe) — optional, dormant until STRIPE_SECRET_KEY set ----
# Orgs stay on the 'free' plan until configured. Webhook endpoint:
#   /api/webhooks/stripe  (add it in the Stripe dashboard; copy the signing secret)
# Subscribe to: checkout.session.completed, customer.subscription.{created,updated,deleted}
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=                    # Stripe price id for the Pro plan
STRIPE_PRICE_ENTERPRISE=            # Stripe price id for the Enterprise plan
# NEXT_PUBLIC_APP_URL is reused as the checkout success/cancel + portal return base.

# ---- Multi-tenancy (orgs) — optional ----
# Single-tenant works with no setup (org_id stays NULL everywhere). To go
# multi-tenant: apply migration 0014, then `pnpm backfill:orgs` to create a
# default org + assign existing users. New users inherit their admin's org.
DEFAULT_ORG_NAME=Default Org

# ---- Bot protection (Cloudflare Turnstile) — optional, dormant until set ----
# Site key renders the challenge widget on signup/login; secret enables the
# server-side token check at /api/security/turnstile. With neither set, forms
# submit normally (mock mode). Get keys at dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Upstash Redis (LLM rate-limit + pipeline lock) — optional, no-op if unset ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
LLM_RATE_PER_MIN=60                 # optional
# Login brute-force lockout (needs Upstash; no-op without it). Failed password
# attempts per email + per IP; lock once the count hits the max within the window.
LOGIN_MAX_ATTEMPTS=5                # optional
LOGIN_LOCKOUT_MINUTES=15           # optional
