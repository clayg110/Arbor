# ============================================================================
# Arbor — environment variables. Copy to `.env.local` and fill in.
# The app runs fully in MOCK MODE with none of these set. Each block "flips on"
# the moment its keys are present.
# ============================================================================

# ---- Supabase (auth, DB, realtime) — enables the whole live backend ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — pipelines + admin user mgmt

# ---- Anthropic (LLM signal extraction) — required for ingestion pipelines ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# ---- Ingestion (cron) ----
CRON_SECRET=                        # Bearer token guarding /api/ingest/* + Vercel cron
SEC_USER_AGENT=Arbor Research you@example.com   # SEC EDGAR requires a descriptive UA
INGEST_RSS_FEEDS=                   # optional comma-separated RSS feed override

# ---- Google Custom Search (private-asset web signals) — optional ----
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# ---- Typesense (search + entity resolution) — optional, falls back to ilike ----
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PORT=                     # optional (default 443 remote / 8108 localhost)
TYPESENSE_PROTOCOL=                 # optional (default https remote / http localhost)

# ---- Upstash Redis (LLM rate-limit + pipeline lock) — optional, no-op if unset ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
LLM_RATE_PER_MIN=60                 # optional
